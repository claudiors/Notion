    {
      "parameters": {
        "jsCode": "const parsear = $('Parsear Resposta').item.json;\nconst revisao = parsear.revisao.revisao_gramatical;\nconst pageId = $input.first().json.id;\n\nconst blocks = [];\n\n// Cabeçalho\nblocks.push({\n  type: \"heading_1\",\n  heading_1: {\n    rich_text: [{ type: \"text\", text: { content: \"📄 Relatório de Revisão Textual\" } }]\n  }\n});\n\n// Informações gerais\nblocks.push({\n  type: \"paragraph\",\n  paragraph: {\n    rich_text: [{ type: \"text\", text: { content: `📁 Arquivo: ${parsear.file_name}` } }]\n  }\n});\n\nblocks.push({\n  type: \"paragraph\",\n  paragraph: {\n    rich_text: [{ type: \"text\", text: { content: `📅 Processado em: ${new Date(parsear.processed_at).toLocaleString('pt-BR')}` } }]\n  }\n});\n\nblocks.push({\n  type: \"paragraph\",\n  paragraph: {\n    rich_text: [{ type: \"text\", text: { content: `📊 Slides analisados: ${revisao.resumo.total_slides_analisados} | Com ajustes: ${revisao.resumo.slides_com_erros} | Sem ajustes: ${revisao.resumo.slides_sem_erros}` } }]\n  }\n});\n\nblocks.push({ type: \"divider\", divider: {} });\n\n// Slides com erros\nconst slidesComErros = revisao.slides.filter(s => s.erros && s.erros.length > 0);\n\nif (slidesComErros.length === 0) {\n  blocks.push({\n    type: \"paragraph\",\n    paragraph: {\n      rich_text: [{ type: \"text\", text: { content: \"✅ Nenhum ajuste necessário. Documento aprovado!\" } }]\n    }\n  });\n} else {\n  for (const slide of slidesComErros) {\n    // Título do slide\n    blocks.push({\n      type: \"heading_2\",\n      heading_2: {\n        rich_text: [{ type: \"text\", text: { content: `🔖 Slide ${slide.slide}${slide.data ? ' — ' + slide.data : ''}` } }]\n      }\n    });\n\n    for (const erro of slide.erros) {\n      blocks.push({\n        type: \"callout\",\n        callout: {\n          rich_text: [{ type: \"text\", text: { content: `⚠️ ${erro.tipo_erro}` } }],\n          icon: { emoji: \"⚠️\" },\n          color: \"yellow_background\"\n        }\n      });\n\n      blocks.push({\n        type: \"paragraph\",\n        paragraph: {\n          rich_text: [\n            { type: \"text\", text: { content: \"Original:  \" }, annotations: { bold: true } },\n            { type: \"text\", text: { content: erro.texto_original } }\n          ]\n        }\n      });\n\n      blocks.push({\n        type: \"paragraph\",\n        paragraph: {\n          rich_text: [\n            { type: \"text\", text: { content: \"Correção:  \" }, annotations: { bold: true, color: \"green\" } },\n            { type: \"text\", text: { content: erro.correcao_sugerida } }\n          ]\n        }\n      });\n\n      blocks.push({\n        type: \"paragraph\",\n        paragraph: {\n          rich_text: [\n            { type: \"text\", text: { content: \"Explicação:  \" }, annotations: { bold: true } },\n            { type: \"text\", text: { content: erro.explicacao } }\n          ]\n        }\n      });\n\n      blocks.push({ type: \"divider\", divider: {} });\n    }\n  }\n}\n\nreturn [{ json: { pageId, blocks } }];"
      },
