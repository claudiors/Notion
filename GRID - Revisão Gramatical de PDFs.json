    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst rawText = response.content[0].text;\n\n// Limpeza agressiva do markdown\nlet cleanText = rawText\n  .replace(/^```json\\s*/i, '')\n  .replace(/^```\\s*/i, '')\n  .replace(/\\s*```$/i, '')\n  .trim();\n\n// Se ainda houver backticks no meio, extrai só o JSON\nconst jsonMatch = cleanText.match(/\\{[\\s\\S]*\\}/);\nif (jsonMatch) {\n  cleanText = jsonMatch[0];\n}\n\nlet parsed;\ntry {\n  parsed = JSON.parse(cleanText);\n} catch (e) {\n  parsed = { raw: rawText, parse_error: true };\n}\n\n// Normaliza estrutura independente do que a IA retornar\nconst rg = parsed.revisao_gramatical || parsed;\nconst resumo = rg.resumo || {};\nconst slides = rg.slides || [];\n\nconst resumoNormalizado = {\n  total_slides_analisados: resumo.total_slides_analisados ?? slides.length ?? 0,\n  total_erros_encontrados: resumo.total_erros_encontrados ?? 0,\n  slides_com_erros: resumo.slides_com_erros ?? slides.filter(s => s.erros && s.erros.length > 0).length ?? 0,\n  slides_sem_erros: resumo.slides_sem_erros ?? slides.filter(s => !s.erros || s.erros.length === 0).length ?? 0\n};\n\nreturn [{\n  json: {\n    file_name: $('Google Drive Trigger').first().json.name,\n    file_id: $('Google Drive Trigger').first().json.id,\n    processed_at: new Date().toISOString(),\n    revisao: {\n      revisao_gramatical: {\n        documento: rg.documento || $('Google Drive Trigger').first().json.name,\n        resumo: resumoNormalizado,\n        slides: slides\n      }\n    }\n  }\n}];"
      },
